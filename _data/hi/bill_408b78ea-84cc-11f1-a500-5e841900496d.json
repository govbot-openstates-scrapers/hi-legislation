{"legislative_session": "2026", "identifier": "SB2132", "title": "RELATING TO DENTAL INSURANCE.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Dental Insurers", "Dental Loss Ratio", "Insurance Commissioner", "Rate Filings", "Reports"], "abstracts": [{"note": "description", "abstract": "Requires dental insurers to file all proposed plan rates and rate changes for a dental insurance plan with the Insurance Commissioner.  Authorizes the Insurance Commissioner to disapprove the proposed plan rate if the dental loss ratio for the plan is less than seventy-five per cent.  Establishes the method to calculate a dental insurer's dental loss ratio.  Requires dental insurers to include dental loss ratio information in their annual reports to the Insurance Commissioner.  Requires the Insurance Commissioner to publish certain report information."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-hi-2026-sb2132"}], "actions": [{"description": "The committee on CPN deferred the measure.", "date": "2026-02-03", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["deferral"], "related_entities": []}, {"description": "The committee(s) on CPN deferred the measure until 02-03-26 9:30AM; Conference Room 229 & Videoconference.", "date": "2026-01-29", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["deferral"], "related_entities": []}, {"description": "The committee(s) on CPN has rescheduled its public hearing to 01-29-26 10:00AM; CR 229 & Videoconference.", "date": "2026-01-28", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "The committee(s) on CPN has scheduled a public hearing on 01-29-26 9:31AM; Conference Room 229 & Videoconference.", "date": "2026-01-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to CPN.", "d