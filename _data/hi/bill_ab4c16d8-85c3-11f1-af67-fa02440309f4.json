{"legislative_session": "2026", "identifier": "HB2480", "title": "RELATING TO EMERGENCY RESPONSE.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Assumption of Risk", "Emergency Responder", "Evacuation", "Immunity"], "abstracts": [{"note": "description", "abstract": "Protects emergency responders from liability during periods of evacuation.  Provides that individuals who wilfully fail to comply with predictive evacuation orders assume the risk and waive liability.  Effective 7/1/3000.  (HD1)"}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-hi-2026-hb2480"}], "actions": [{"description": "The committee(s) on JHA recommend(s) that the measure be deferred.", "date": "2026-02-25", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["deferral"], "related_entities": []}, {"description": "Bill scheduled to be heard by JHA on Wednesday, 02-25-26 2:00PM in House conference room 325 VIA VIDEOCONFERENCE.", "date": "2026-02-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Passed Second Reading as amended in HD 1 and referred to the committee(s) on JHA with none voting aye with reservations; none voting no (0) and none excused (0).", "date": "2026-02-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-2", "referral-committee"], "related_entities": [{"name": "Judiciary & Hawaiian Affairs", "entity_type": "organization", "organization_id": null}]}, {"description": "Reported from PBS (Stand. Com. Rep. No. 394-26) as amended in HD 1, recommending passage on Second Reading and referral to JHA.", "date": "2026-02-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "The committee on PBS recommend that the measure be PASSED, WITH AMENDMENTS. The votes were as follows: 9 Ayes: Representative(s) Belatti, Hashem, Ichi