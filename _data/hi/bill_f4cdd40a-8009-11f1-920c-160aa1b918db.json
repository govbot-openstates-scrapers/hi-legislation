{"legislative_session": "2026", "identifier": "SB2481", "title": "RELATING TO CHILD WELFARE SERVICES.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Child Welfare Services", "DHS", "GRACIE Act", "Interviews", "Penalty", "Recordings"], "abstracts": [{"note": "description", "abstract": "Requires the Department of Human Services to record any child welfare interview conducted by the Department when administering certain child welfare services.  Requires the Department to store the recordings for a minimum of five years and under certain conditions.  Prohibits the sharing of the recordings unless certain conditions are met. Establishes criminal penalties for violating prohibitions against sharing of the recordings."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-hi-2026-sb2481"}], "actions": [{"description": "Referred to HHS, JDC/WAM.", "date": "2026-01-28", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Health and Human Services", "entity_type": "organization", "organization_id": null}, {"name": "Judiciary", "entity_type": "organization", "organization_id": null}, {"name": "Ways and Means", "entity_type": "organization", "organization_id": null}]}, {"description": "Passed First Reading.", "date": "2026-01-22", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Introduced.", "date": "2026-01-22", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}], "sponsorships": [{"name": "GABBARD", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"GABBARD\"}", "organization_id": null}, {"name": "CHANG", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"CHANG\"}", "organization_id": null}, {"na