{"legislative_session": "2026", "identifier": "SB3321", "title": "RELATING TO AQUACULTURE.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Animal Industry Division", "Appropriation ($)", "Aquaculture", "Biocontainment Standards", "Biological Aquatic Risk-Based Framework", "Biosecurity", "DAB", "Interagency Coordination", "Permitting"], "abstracts": [{"note": "description", "abstract": "Requires establishment of a biological aquatic risk-based framework for assessment and approval of aquatic livestock importation and movement.  Authorizes the Division of Animal Industry of the Department of Agriculture and Biosecurity to adopt rules implementing species risk categorization, tiered biocontainment standards, per-arrival disease testing, and interagency coordination procedures.  Establishes an interagency working group.  Requires development of species-specific risk matrices, interagency working group coordination with automatic permit approval timelines, and performance accountability.  Establishes an implementation timeline.  Appropriates moneys."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-hi-2026-sb3321"}], "actions": [{"description": "Referred to AEN, WAM.", "date": "2026-02-02", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Agriculture and Environment", "entity_type": "organization", "organization_id": null}, {"name": "Ways and Means", "entity_type": "organization", "organization_id": null}]}, {"description": "Passed First Reading.", "date": "2026-01-30", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Introduced.", "date": "2026-01-30", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}], "sponsorships": [{"name": "GABBARD", "classification": "primary", "entity_t