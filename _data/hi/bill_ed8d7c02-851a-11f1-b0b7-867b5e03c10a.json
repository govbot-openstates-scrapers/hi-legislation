{"legislative_session": "2026", "identifier": "HB2221", "title": "RELATING TO THE RESIDENTIAL LANDLORD-TENANT CODE.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Certified Copies", "Credit Report", "Criminal Background Check", "Rental Application Screening Fee", "Reusable Tenant Screening Report"], "abstracts": [{"note": "description", "abstract": "Prohibits a landlord or the landlord's agent from charging an application fee for a criminal background check or credit report if an applicant provides a certified copy of a recent criminal background check or credit report.  Prohibits a landlord or the landlord's agent from charging an application fee if a recent comprehensive reusable tenant screening report is available.  Requires a landlord or the landlord's agent to provide, upon request, a certified copy of an applicant's criminal background check or credit report."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-hi-2026-hb2221"}], "actions": [{"description": "Referred to CPC, FIN, referral sheet 5", "date": "2026-01-30", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Consumer Protection & Commerce", "entity_type": "organization", "organization_id": null}, {"name": "Finance", "entity_type": "organization", "organization_id": null}]}, {"description": "Introduced and Pass First Reading.", "date": "2026-01-28", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "Pending introduction.", "date": "2026-01-26", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}], "sponsorships": [{"name": "HOLT", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"HOLT\"}", "organization_id": null}, {"name": "CHUN", "classification": "primary", "en