{"legislative_session": "2026", "identifier": "SB2161", "title": "RELATING TO LAND USE.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Department of Agriculture and Biosecurity", "Department of Land and Natural Resources", "Land Use", "Plant and Animal Sanctuaries", "Rodeo Activities", "Rodeos", "Rules"], "abstracts": [{"note": "description", "abstract": "Authorizes plant and animal sanctuaries with ancillary functions and related support and visitor facilities, rodeos, and rodeo activities on lands that are zoned for agricultural use.  Requires the applicable department that owns, manages, controls, or leases the land used for rodeos or rodeo activities to adopt rules to restrict the scale of rodeo activities.  Defines the terms \"rodeo or rodeo activities\" and \"plant and animal sanctuaries\".  Effective 7/1/2050.  (SD1)"}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-hi-2026-sb2161"}], "actions": [{"description": "Referred to WAL, CAA, JHA, referral sheet 17", "date": "2026-03-12", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Water & Land", "entity_type": "organization", "organization_id": null}, {"name": "Culture & Arts", "entity_type": "organization", "organization_id": null}, {"name": "Judiciary & Hawaiian Affairs", "entity_type": "organization", "organization_id": null}]}, {"description": "Pass First Reading", "date": "2026-03-12", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Received from Senate (Sen. Com. No. 185) in amended form (SD 1).", "date": "2026-03-10", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction", "receipt"], "related_entities": []}, {"description": "Passed Third Reading, as amended (SD 1). Ayes, 25; Aye(s) with reservations: none .  Noes, 0 (none). Excused, 0 (non