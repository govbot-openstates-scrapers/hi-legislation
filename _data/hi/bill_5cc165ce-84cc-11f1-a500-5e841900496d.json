{"legislative_session": "2026", "identifier": "SB2421", "title": "RELATING TO CANNABIS.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Adult-Use Cannabis", "Appropriations ($)", "DCCA", "DOA", "DOH", "DoTax", "Hawaii Cannabis and Hemp Office", "Hemp", "Medical Cannabis"], "abstracts": [{"note": "description", "abstract": "Establishes the Hawaii Cannabis and Hemp Office within the Department of Commerce and Consumer Affairs to regulate all aspects of the cannabis plant.  Contingent upon specific changes at the federal level or a state constitutional amendment, legalizes the personal adult use of cannabis and decriminalizes certain marijuana-related offenses.  Beginning 1/1/2027, establishes taxes on cannabis sales.  Adds new traffic offenses relating to the consumption or possession of marijuana or marijuana concentrate.  Transfers the personnel and assets of the Department of Health and assets of the Department of Agriculture relating to cannabis and hemp to the Hawaii Cannabis and Hemp Office.  Establishes various positions within state entities.  Appropriates funds."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-hi-2026-sb2421"}], "actions": [{"description": "The committee on CPN deferred the measure.", "date": "2026-02-18", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["deferral"], "related_entities": []}, {"description": "The committee on HHS deferred the measure.", "date": "2026-02-18", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["deferral"], "related_entities": []}, {"description": "The committee(s) on CPN/HHS deferred the measure until 02-18-26 10:06AM; Conference Room 229 & Videoconference.", "date": "2026-02-17", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["deferral"], "related_entities": []}, {"description": "The committee(s) on CPN/HHS has scheduled a public hearing on 02-17-26 9:45AM; Conference Room 229 & Videoconference.", "date": "2026-02-13", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to CPN/HHS, WAM/JDC.", "date": "2026-01-28", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Commerce and Consumer Protection", "entity_type": "organization", "organization_id": null}, {"name": "Health and Human Services", "entity_type": "organization", "organization_id": null}, {"name": "Ways and Means", "entity_type": "organization", "organization_id": null}, {"name": "Judiciary", "entity_type": "organization", "organization_id": null}]}, {"description": "Introduced and passed First Reading.", "date": "2026-01-21", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "Pending Introduction.", "date": "2026-01-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}], "sponsorships": [{"name": "SAN BUENAVENTURA", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"SAN BUENAVENTURA\"}", "organization_id": null}, {"name": "HASHIMOTO", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"HASHIMOTO\"}", "organization_id": null}], "related_bills": [{"identifier": "HB 1625", "legislative_session": "2026 Regular Session", "relation_type": "companion"}], "versions": [{"note": "SB2421", "links": [{"url": "https://data.capitol.hawaii.gov/sessions/session2026/bills/SB2421_.HTM", "media_type": "text/html"}, {"url": "https://data.capitol.hawaii.gov/sessions/session2026/bills/SB2421_.PDF", "media_type": "application/pdf"}], "date": "", "classification": ""}], "documents": [], "citations": [], "sources": [{"url": "https://capitol.hawaii.gov/session/measure_indiv.aspx?billtype=SB&billnumber=24