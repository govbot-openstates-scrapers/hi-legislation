{"legislative_session": "2026", "identifier": "HB1883", "title": "RELATING TO EPINEPHRINE.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Beach Parks", "Counties", "County Lifeguards", "Emergency Care", "Epinephrine Auto-Injectors", "Health Care Providers", "Liability", "Pharmacists", "Prescriptions", "Training"], "abstracts": [{"note": "description", "abstract": "Beginning 1/1/2027, authorizes county lifeguards providing services at a county or state beach park to administer epinephrine auto-injectors to render emergency care to another person.  Requires the counties to approve training providers and establish standards for the use and administration of epinephrine auto-injectors.  Establishes requirements for health care providers to issue prescriptions for, and pharmacists to dispense, epinephrine auto-injectors to counties or county life guards.  Establishes certain limitations of liability."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-hi-2026-hb1883"}], "actions": [{"description": "Referred to HLT/LAB, WAL, JHA, referral sheet 2", "date": "2026-01-26", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Health", "entity_type": "organization", "organization_id": null}, {"name": "Labor", "entity_type": "organization", "organization_id": null}, {"name": "Water & Land", "entity_type": "organization", "organization_id": null}, {"name": "Judiciary & Hawaiian Affairs", "entity_type": "organization", "organization_id": null}]}, {"description": "Introduced and Pass First Reading.", "date": "2026-01-26", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction", "reading-1"], "related_entities": []}, {"description": "Pending introduction.", "date": "2026-01-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}], "sponsorships": [{"name":