{"legislative_session": "2026", "identifier": "SB2883", "title": "RELATING TO BUILDING CODES.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Apartment Buildings", "Category 3", "Category 5", "Hurricanes", "Residential Safe Rooms", "Single Family Residences"], "abstracts": [{"note": "description", "abstract": "Requires all single family residences and apartment buildings built after 1/1/2027 include a safe room that can withstand winds of two hundred miles per hour or higher.  Requires single\u2011family residences and apartment buildings built after 1/1/2027 be built to withstand Category 3 hurricanes when located in an area with winds of one hundred thirty miles per hour and a Category 5 hurricane when located in an area with winds of one hundred forty miles per hour or higher."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-hi-2026-sb2883"}], "actions": [{"description": "Referred to PSM, JDC.", "date": "2026-01-30", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Public Safety and Military Affairs", "entity_type": "organization", "organization_id": null}, {"name": "Judiciary", "entity_type": "organization", "organization_id": null}]}, {"description": "Passed First Reading.", "date": "2026-01-26", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Introduced.", "date": "2026-01-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}], "sponsorships": [{"name": "GABBARD", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"GABBARD\"}", "organization_id": null}], "related_bills": [], "versions": [{"note": "SB2883", "links": [{"url": "https://data.capitol.hawaii.gov/sessions/session2026/bills/SB2883_.HTM", "media_type": "text/ht