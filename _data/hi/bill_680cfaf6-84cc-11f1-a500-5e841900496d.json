{"legislative_session": "2026", "identifier": "SB2542", "title": "RELATING TO HOUSING.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Department of Education", "Employee Housing", "Public School Facilities"], "abstracts": [{"note": "description", "abstract": "Requires the Department of Education to give reasonable consideration to making all or portions of the facilities of a public school available to housing development for certain employees of the Department when closing the public school.  Requires the Department of Education to identify unused public school facilities that may be appropriate for employee housing and inventory suitable grounds available upon public school closure for potential development of employee housing."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-hi-2026-sb2542"}], "actions": [{"description": "Referred to EDU, WAM.", "date": "2026-01-28", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Education", "entity_type": "organization", "organization_id": null}, {"name": "Ways and Means", "entity_type": "organization", "organization_id": null}]}, {"description": "Passed First Reading.", "date": "2026-01-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Introduced.", "date": "2026-01-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}], "sponsorships": [{"name": "HASHIMOTO", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"HASHIMOTO\"}", "organization_id": null}, {"name": "CHANG", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"CHANG\"}", "organization_id": null}, {"name": "Elefante", "classification": "cosponsor", "entity_type": "person", "pr