{"legislative_session": "2026", "identifier": "SB2889", "title": "RELATING TO AIRCRAFT OPERATIONS.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Civil Penalty", "Commercial Helicopter Tour", "DOT", "Permits", "Public Process", "Report", "Restriction", "Sensitive Area"], "abstracts": [{"note": "description", "abstract": "Restricts commercial helicopter tour operations over sensitive areas designated by the Department of Transportation through public process.  Requires the Department of Transportation to enforce restrictions through a permit process, flight tracking, noise monitoring, complaint investigation, and the issuance of a civil penalty for each violation.  Requires an annual report to the Legislature by the Department of Transportation."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-hi-2026-sb2889"}], "actions": [{"description": "Referred to TRS, JDC/WAM.", "date": "2026-01-30", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Transportation", "entity_type": "organization", "organization_id": null}, {"name": "Judiciary", "entity_type": "organization", "organization_id": null}, {"name": "Ways and Means", "entity_type": "organization", "organization_id": null}]}, {"description": "Passed First Reading.", "date": "2026-01-26", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Introduced.", "date": "2026-01-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}], "sponsorships": [{"name": "GABBARD", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"GABBARD\"}", "organization_id": null}, {"name": "CHANG", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"CHANG\"}", "organi