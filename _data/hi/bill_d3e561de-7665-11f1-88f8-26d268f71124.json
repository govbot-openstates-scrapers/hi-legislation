{"legislative_session": "2026", "identifier": "SB3190", "title": "RELATING TO FIREWORKS.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Asset Forfeiture", "Fines", "Fireworks", "Increase", "Production", "Transportation"], "abstracts": [{"note": "description", "abstract": "Requires individuals to obtain a license to transport fireworks.  Prohibits the transportation or production of fireworks without a valid license.  Establishes a minimum fine of $10,000 for the importation, storage, transport, distribution, or production of fireworks without a valid license.  Clarifies that certain assets are subject to forfeiture for violations of section 132D\u201114(a)(1), HRS.  Requires any person who reports information leading directly to a forfeiture for violations of section 132D\u201114(a)(1), HRS, to receive fifty per cent of the total value of the assets subject to forfeiture."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-hi-2026-sb3190"}], "actions": [{"description": "Referred to PSM/CPN, JDC/WAM.", "date": "2026-02-02", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Public Safety and Military Affairs", "entity_type": "organization", "organization_id": null}, {"name": "Commerce and Consumer Protection", "entity_type": "organization", "organization_id": null}, {"name": "Judiciary", "entity_type": "organization", "organization_id": null}, {"name": "Ways and Means", "entity_type": "organization", "organization_id": null}]}, {"description": "Passed First Reading.", "date": "2026-01-28", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "Introduced.", "date": "2026-01-28", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}], "sponsorships": [{"name": "FUKUNAGA", "classification"