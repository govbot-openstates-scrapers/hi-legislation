{"legislative_session": "2026", "identifier": "SB2967", "title": "RELATING TO ARTIFICIAL INTELLIGENCE.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["Algorithmic Discrimination", "Appeals", "Artificial Intelligence", "Attorney General", "Consumer Protection", "Disclosures", "Executive Director", "Office of Consumer Protection", "Risk Management", "Unfair and Deceptive Acts or Practices"], "abstracts": [{"note": "description", "abstract": "Establishes consumer protection requirements for the use of artificial intelligence systems in consumer interactions and consequential decisions, including disclosures, documentation, and a right to correction, appeal, and human review.  Makes certain violations an unfair or deceptive act or practice.  Requires risk management and impact assessments for high-risk artificial intelligence systems.  Requires incident reports to the Executive Director of the Office of Consumer Protection and the Attorney General."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-hi-2026-sb2967"}], "actions": [{"description": "The committee on LBT deferred the measure.", "date": "2026-02-11", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["deferral"], "related_entities": []}, {"description": "The committee(s) on LBT has scheduled a public hearing on 02-11-26 3:00PM; Conference Room 225 & Videoconference.", "date": "2026-02-06", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Referred to LBT, CPN.", "date": "2026-01-30", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Labor and Technology", "entity_type": "organization", "organization_id": null}, {"name": "Commerce and Consumer Protection", "entity_type": "organization", "organization_id": null}]}, {"description": "Passed First Reading.", "date": "2026-01-2