{"legislative_session": "2026", "identifier": "SB2121", "title": "RELATING TO EMERGENCY ANNOUNCEMENTS.", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["American Sign Language", "Broadcast Media", "Emergency", "Official Announcements", "Sign Language Interpreter"], "abstracts": [{"note": "description", "abstract": "Requires the Governor or mayor of a county to provide an American Sign Language interpreter during each official announcement broadcast via television or the Internet during a state of emergency.  Requires the Governor or mayor of a county to ensure, to the fullest extent possible, that the American Sign Language interpreter's face, body, arms, and hands are visible during the broadcast.  Requires a news media outlet to display the American Sign Language interpreter in a picture-in-picture window during broadcasts of official emergency announcements."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-hi-2026-sb2121"}], "actions": [{"description": "The committee on PSM deferred the measure.", "date": "2026-02-18", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["deferral"], "related_entities": []}, {"description": "The committee(s) on PSM has scheduled a public hearing on 02-18-26 3:00PM; Conference Room 016 & Videoconference.", "date": "2026-02-12", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Re-Referred to PSM, WAM.", "date": "2026-02-10", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Public Safety and Military Affairs", "entity_type": "organization", "organization_id": null}, {"name": "Ways and Means", "entity_type": "organization", "organization_id": null}]}, {"description": "Referred to PSM/HHS, WAM.", "date": "2026-01-22", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["refer